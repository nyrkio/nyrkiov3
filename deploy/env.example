# Copy to /etc/nyrkio-v3/env and fill in the secrets. Root-read-only:
#   sudo install -o root -g root -m 0600 env.example /etc/nyrkio-v3/env
#
# Public origin + path the service is served from. MUST include the
# /v3 prefix because nginx path-routes /v3/* to this backend.
NYRKIO_BASE_URL=https://staging.nyrkio.com/v3

# Where the (JSON) store snapshot lives. Must be writable by the
# systemd User= (nyrkio). The directory is listed in ReadWritePaths=
# of the unit file.
NYRKIO_SNAPSHOT_PATH=/var/lib/nyrkio-v3/store.json

# Path to AuroraBorealis/static/ so the SPA is served alongside the
# API. Clone the AuroraBorealis repo next to this one and point here.
NYRKIO_STATIC_DIR=/opt/nyrkio-v3/AuroraBorealis/static

# Bind address.
# If nginx runs on the same host NOT inside a container, keep this on
# 127.0.0.1 — the loopback stays private to the host.
# If nginx runs inside Docker (the existing staging setup does), the
# container can't reach the host's 127.0.0.1. Bind on the Docker
# bridge IP instead (check with `docker network inspect`):
#   NYRKIO_BIND=172.17.0.1:8123   # default bridge
# Or bind on 0.0.0.0 and rely on firewalling for privacy.
NYRKIO_BIND=172.17.0.1:8123

# GitHub OAuth app credentials. Register the app at
# https://github.com/settings/applications/new with callback
# https://staging.nyrkio.com/v3/oauth/callback
NYRKIO_GITHUB_CLIENT_ID=
NYRKIO_GITHUB_CLIENT_SECRET=

# 32+ bytes of random, used for cookie HMAC. `openssl rand -hex 32`.
NYRKIO_SESSION_SECRET=

# App-level PAT used by the public /connect path and the webhook
# path (classic token with `public_repo` scope is enough for public
# repos; `repo` if you also want to ingest private ones via this
# token). See the /home/claude GH PAT this session used for a
# reference scope.
NYRKIO_APP_GITHUB_PAT=
