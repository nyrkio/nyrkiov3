## Add inside the existing `staging.nyrkio.com` server {} block in
## /home/claude/nyrkio/nginx/nginx.conf. The trailing slash on both the
## location and proxy_pass means /v3/foo is forwarded as /foo to the
## backend — matches the relative-URL style the app uses.
##
## `host.docker.internal` requires the nginx service in docker-compose
## to declare:
##   extra_hosts:
##     - "host.docker.internal:host-gateway"
## (a one-line change inside the nginx service in docker-compose.yml).

location /v3/ {
    proxy_pass http://host.docker.internal:8123/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Prefix /v3;
    # The webhook payload is small but logs fetched during ingest can
    # be large (a few MB per UnoDB job). Bump the read timeout so the
    # 202 + background pattern isn't starved on slow GitHub responses.
    proxy_read_timeout 120s;
    # Pass Set-Cookie through unchanged.
    proxy_pass_header Set-Cookie;
}
