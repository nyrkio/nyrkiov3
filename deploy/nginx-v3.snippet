## Add inside the existing `staging.nyrkio.com` server {} block in
## /home/claude/nyrkio/nginx/nginx.conf. The trailing slash on both the
## location and proxy_pass means /v3/foo is forwarded as /foo to the
## backend — matches the relative-URL style the app uses.
##
## The backend is reached via the Docker bridge gateway IP. On Linux,
## `host.docker.internal` does NOT resolve inside a container by
## default and `extra_hosts: host-gateway` is finicky; the bridge IP
## is what actually works. Check yours with:
##   docker network inspect <nginx's network> | grep Gateway
## It's typically 172.17.0.1 (default bridge) or a project-specific
## value like 172.7.0.1 / 172.18.0.1.

# UI + auth routes: strip /v3/ so the backend sees /login,
# /oauth/callback, /api/v3/... directly.
location /v3/ {
    proxy_pass http://172.17.0.1:8123/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Prefix /v3;
    # The webhook payload is small but logs fetched during ingest can
    # be large (a few MB per UnoDB job). Bump the read timeout so the
    # 202 + background pattern isn't starved on slow GitHub responses.
    proxy_read_timeout 120s;
    # Pass Set-Cookie through unchanged.
    proxy_pass_header Set-Cookie;
}

# Raw API — /api/v3/* forwarded through WITHOUT the /v3/ prefix. Lets
# external callers (GitHub webhooks, CI ingest scripts, curl) hit the
# backend at its canonical path:
#   https://staging.nyrkio.com/api/v3/webhooks/github
#   https://staging.nyrkio.com/api/v3/ingest/gh/{owner}/{repo}
# and not have to know about the UI path prefix.
location /api/v3/ {
    proxy_pass http://172.17.0.1:8123/api/v3/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
}
